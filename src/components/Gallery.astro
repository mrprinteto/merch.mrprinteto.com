---
import { getCollection } from 'astro:content';
import Section from './Section.astro';
import Container from './Container.astro';
import ProjectCard from './ProjectCard.astro';

const projects = await getCollection('projects');
// Highlighted projects first
const sorted = projects.sort((a, b) =>
  (b.data.destacado ? 1 : 0) - (a.data.destacado ? 1 : 0)
);
---

<Section id="galeria">
  <Container>
    <div class="text-center mb-12 space-y-3 animate-on-scroll">
      <p class="label-mono">// PORTFOLIO</p>
      <h2 class="section-heading">Últimos trabajos</h2>
      <p class="text-off-white/60 max-w-lg mx-auto">
        Proyectos reales, para empresas reales. Cada pieza es diseñada y fabricada
        desde Madrid.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sorted.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>

    <div class="text-center mt-12 animate-on-scroll">
      <a href="#contacto" class="btn-ghost">
        <i class="fa-solid fa-plus" aria-hidden="true"></i>
        Cuéntame tu proyecto
      </a>
    </div>
  </Container>
</Section>
