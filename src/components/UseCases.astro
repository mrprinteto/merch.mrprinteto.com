---
import Section from './Section.astro';
import Container from './Container.astro';
import ServiceCard from './ServiceCard.astro';

const services = [
  {
    icon: 'fa-solid fa-dumbbell',
    title: 'Merch para Boxes y gimnasios',
    description:
      'Llaveros, parches, imanes, etc.\nDecoración para tu Box o gimnasio.\nPensado para propietarios que quieren dar algo diferente a su comunidad.',
  },
  {
    icon: 'fa-solid fa-medal',
    title: 'Medallas y trofeos para eventos',
    description:
      'Medallas y trofeos personalizados con posibilidad de grabado con láser.\nPiezas a la altura de tu competición, listas antes de la fecha.',
  },
  {
    icon: 'fa-solid fa-gift',
    title: 'Regalos corporativos',
    description:
      'Detalla a tu equipo o a tus clientes con algo que no se compra en Amazon. Personal, funcional y memorable. Nada de bolígrafos genéricos.',
  },
  {
    icon: 'fa-solid fa-palette',
    title: 'Personalización libre',
    description:
      'Trae tu idea, tu boceto o tu fichero 3D. Lo adaptamos, lo imprimimos con el material que elijas y lo enviamos con tu identidad de marca.',
  },
];
---

<Section id="servicios">
  <Container>
    <div class="text-center mb-12 space-y-3 animate-on-scroll">
      <p class="label-mono">// SERVICIOS</p>
      <h2 class="section-heading">¿Para qué lo necesitas?</h2>
      <p class="text-off-white/60 max-w-xl mx-auto">
        Impresión 3D personalizada aplicada a negocio real. No son prototipados si no piezas
        terminadas con TU marca.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {services.map((service, i) => (
        <ServiceCard
          icon={service.icon}
          title={service.title}
          description={service.description}
          delay={i + 1}
        />
      ))}
    </div>
  </Container>
</Section>
