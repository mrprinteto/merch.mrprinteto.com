---
// Hero section: headline, subcopy, CTAs, stats, decorative visual
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center pt-24 pb-20 overflow-hidden"
>
  <!-- Ambient glow background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute top-1/4 left-1/3 w-[500px] h-[500px] rounded-full blur-3xl opacity-25"
      style="background: var(--accent);"
    ></div>
    <div
      class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full blur-3xl opacity-20"
      style="background: var(--surface);"
    ></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Copy -->
      <div class="space-y-7">
        <p class="label-mono animate-on-scroll">// YOUR OWN MERCH by PRINTETO</p>

        <h1
          class="text-5xl sm:text-6xl lg:text-7xl font-bold text-off-white leading-[1.05] animate-on-scroll"
          style="letter-spacing: -0.02em;"
          data-delay="1"
        >
          Merch personalizado<br />
          <span style="color: var(--accent);">impreso en 3D.</span>
        </h1>

        <p
          class="text-lg text-off-white/70 leading-relaxed max-w-lg animate-on-scroll"
          data-delay="2"
        >
          Pide tu catálogo privado personalizado para tu BOX de entrenamiento, gimnasio, marca o evento de manera <span class="text-off-white">GRATUITA</span>.<br />
          <span style="color: var(--color-lavender);" class="font-semibold">¡Sin cobros mensuales ni suscripciones!</span><br />
          Aplicamos descuentos por volumen.</br> Todo fabricado en Madrid.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 animate-on-scroll" data-delay="3">
          <a href="#contacto" class="btn-primary">
            Pide presupuesto
            <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
          </a>
          <a href="#galeria" class="btn-ghost">
            Ver proyectos
          </a>
        </div>
        <div class="flex flex-wrap items-center gap-6 pt-2 animate-on-scroll" data-delay="4">
          <!--<div>
            <p class="text-2xl font-bold text-off-white">+50</p>
            <p class="label-mono mt-0.5">proyectos</p>
          </div>
          <div class="w-px h-10" style="background: var(--border);"></div>-->
          <div>
            <p class="text-2xl font-bold text-off-white">10–15</p>
            <p class="label-mono mt-0.5">días entrega</p>
          </div>
          <div class="w-px h-10" style="background: var(--border);"></div>
          <div>
            <p class="text-2xl font-bold text-off-white">0</p>
            <p class="label-mono mt-0.5">uds. mínimo</p>
          </div>
        </div>
      </div>

      <!-- Decorative visual -->
      <div class="relative hidden lg:flex justify-center animate-on-scroll" data-delay="2">
        <div class="relative w-full max-w-sm aspect-square">
          <div
            class="absolute -inset-6 rounded-3xl blur-2xl opacity-30"
            style="background: var(--accent);"
            aria-hidden="true"
          ></div>

          <img
            src="https://images.pexels.com/photos/31370888/pexels-photo-31370888.jpeg"
            alt="Catálogos privados personalizados."
            class="relative w-full h-full object-cover rounded-2xl shadow-2xl border border-white/10"
            loading="eager"
          />
        </div>
      </div>

    </div>
  </div>
</section>
