# Email service (https://resend.com)
# Required for the contact form to work.
# The sender domain (mrprinteto.com) must be verified in Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Destination inbox for contact form submissions
TO_EMAIL=merch@mrprinteto.com

# Font Awesome Kit URL (https://fontawesome.com/kits)
# Your kit script URL, e.g. https://kit.fontawesome.com/XXXXXXXX.js
# If omitted, icons will not render.
PUBLIC_FA_KIT_URL=https://kit.fontawesome.com/XXXXXXXX.js
